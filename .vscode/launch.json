  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "TypeScript",
      "runtimeArgs": ["--no-lazy", "-r", "ts-node/register"],
      "args": ["${relativeFile}"],
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "env": {
        "TS_NODE_FILES": "true"
      }
    }
  ]
}
